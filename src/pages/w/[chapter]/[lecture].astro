---
import Layout from '../../../layouts/Layout.astro';
import VideoPlayer from '../../../components/VideoPlayer.astro';
import { ChevronRight } from 'lucide-astro';
import data from '../../../../public/data.json';

export function getStaticPaths() {
  const paths: { params: { chapter: string; lecture: string; } }[] = [];
  const chapters = data.classes || [];
  chapters.forEach((chapter, cIndex) => {
    const lectures = chapter.lectures || [];
    lectures.forEach((_, lIndex) => {
      paths.push({
        params: {
          chapter: cIndex.toString(),
          lecture: lIndex.toString()
        }
      });
    });
  });
  return paths;
}

const chapterIndex = Number(Astro.params.chapter);
const lectureIndex = Number(Astro.params.lecture);

const chapters = data.classes || [];
const chapter = chapters[chapterIndex];
const lecture = chapter?.lectures?.[lectureIndex];

if (!chapter || !lecture) {
  return new Response("No data found.", { status: 404 });
}

const nextLectureIndex = lectureIndex + 1;
const hasNextLecture = nextLectureIndex < (chapter.lectures?.length || 0);
const nextLecture = hasNextLecture ? chapter.lectures![nextLectureIndex] : undefined;
const nextLectureUrl = hasNextLecture ? `/w/${chapterIndex}/${nextLectureIndex}` : undefined;
---

<Layout title={`مشاهدة | ${lecture.title}`}>
  <div class="min-h-screen flex flex-col">
    <!-- Navbar / Header for Watch Page -->
    <header class="w-full p-4 md:p-6 flex items-center justify-between glass-panel border-b border-white/10 z-40 sticky top-0">
      <a
        href={`/c/${chapterIndex}`}
        class="flex items-center gap-2 text-white/80 hover:text-white hover:bg-white/10 px-4 py-2 rounded-xl transition-all font-medium"
      >
        <ChevronRight class="w-5 h-5" />
        <span>العودة للمحاضرات</span>
      </a>

      <div class="flex items-center gap-3">
        <h1 class="text-lg md:text-xl font-bold text-white hidden sm:block">
          {chapter.name}
        </h1>
        <img src="/icon.png" alt="Logo" class="w-10 h-10 object-contain drop-shadow-md" />
      </div>
    </header>

    <!-- Main Content: Theater Mode -->
    <main class="flex-1 w-full max-w-7xl mx-auto p-4 md:p-8 flex flex-col items-center justify-center gap-8 animate-[fadeIn_0.5s_ease-out]">

      <div class="w-full text-right self-start md:px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-white drop-shadow-md mb-2">{lecture.title || `محاضرة ${lectureIndex + 1}`}</h2>
        <p class="text-accent text-sm md:text-base font-medium">{chapter.name}</p>
      </div>

      <!-- Video Player Component -->
      <VideoPlayer
        url={lecture.url}
        title={lecture.title}
        nextLectureUrl={nextLectureUrl}
        nextLectureTitle={nextLecture?.title}
      />

      <!-- Keyboard Shortcuts Hint (Desktop only) -->
      <div class="hidden md:flex items-center justify-center gap-6 mt-4 p-4 glass-card rounded-xl text-white/60 text-sm">
        <div class="flex items-center gap-2">
          <kbd class="px-2 py-1 bg-white/10 rounded border border-white/20 font-sans text-xs">Space</kbd>
          <span>إيقاف/تشغيل</span>
        </div>
        <div class="flex items-center gap-2">
          <kbd class="px-2 py-1 bg-white/10 rounded border border-white/20 font-sans text-xs">F</kbd>
          <span>ملء الشاشة</span>
        </div>
        <div class="flex items-center gap-2">
          <kbd class="px-2 py-1 bg-white/10 rounded border border-white/20 font-sans text-xs">←</kbd>
          <kbd class="px-2 py-1 bg-white/10 rounded border border-white/20 font-sans text-xs">→</kbd>
          <span>تقديم/تأخير 10ث</span>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.98); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
