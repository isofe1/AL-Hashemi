---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import LectureCard from '../../components/LectureCard.astro';
import data from '../../../public/data.json';

export function getStaticPaths() {
  const chapters = data.classes || [];
  return chapters.map((_, index) => ({
    params: { chapter: index.toString() }
  }));
}

const activeChapterIndex = Number(Astro.params.chapter);
const chapters = data.classes || [];
const activeChapter = chapters[activeChapterIndex];
const lectures = activeChapter?.lectures || [];

if (!activeChapter) {
  return new Response("No data found.", { status: 404 });
}
---

<Layout title="الهاشمي | المنصة التعليمية">
  <div class="min-h-screen md:pr-80 transition-all duration-300">
    <Sidebar activeChapterIndex={activeChapterIndex} />

    <main class="relative px-4 py-8 md:px-10 max-w-7xl mx-auto">
      <header class="flex items-center justify-between gap-6 mb-8 p-6 glass-card rounded-2xl">
        <div>
          <p class="text-white/80 font-medium mb-2 text-sm tracking-wide">
            انستا: <a href="https://www.instagram.com/do7d_/" target="_blank" class="font-bold text-white hover:text-accent transition-colors">@do7d_</a>
          </p>
          <h2 class="text-2xl md:text-4xl font-bold text-white drop-shadow-md">
            {activeChapter.name}
          </h2>
        </div>
        <img src="/icon.png" alt="شعار المنصة" class="w-16 h-16 md:w-20 md:h-20 object-contain drop-shadow-[0_8px_20px_rgba(30,144,255,0.3)] hidden sm:block" />
      </header>

      {lectures.length > 0 ? (
        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 animate-[fadeIn_0.4s_ease-out]">
          {lectures.map((lecture, index) => (
            <LectureCard
              lecture={lecture}
              chapterIndex={activeChapterIndex}
              lectureIndex={index}
              chapterName={activeChapter.name}
            />
          ))}
        </section>
      ) : (
        <section class="glass-panel p-8 text-center rounded-2xl">
          <p class="text-white/70 text-lg">لا توجد محاضرات في هذا الفصل حالياً.</p>
        </section>
      )}
    </main>
  </div>
</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
